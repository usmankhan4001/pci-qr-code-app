# Bundled Postgres credentials for the one-container Docker deployment.
# The container generates DATABASE_URL internally from these values.
POSTGRES_USER="pciqr"
POSTGRES_PASSWORD="replace-with-a-strong-database-password"
POSTGRES_DB="pci_qr"

# For non-Docker local development only, point DATABASE_URL at your local DB.
# DATABASE_URL="postgresql://pciqr:pciqr_dev_pw@localhost:5432/pci_qr?schema=public"

# Auth.js session encryption secret. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-base64-string"

# Public URL of this app (the admin/library UI).
NEXT_PUBLIC_BASE_URL="https://qrapp.pcirealestate.com"

# Public URL used as the base for QR tracking links (the "/q/[shortcode]"
# redirect). Can be the same host as NEXT_PUBLIC_BASE_URL, or a dedicated
# short-link subdomain (e.g. https://qr.pcirealestate.com) pointed at the
# same app.
NEXT_PUBLIC_REDIRECT_BASE_URL="https://qr.pcirealestate.com"

# One-time seed script credentials (prisma/seed.ts). Change the password
# immediately after first login; these env vars are only read at seed time.
SEED_ADMIN_EMAIL="it-team@pcirealestate.com"
SEED_ADMIN_PASSWORD="change-me-before-seeding"
