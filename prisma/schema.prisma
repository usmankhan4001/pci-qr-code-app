// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Auth.js models (credentials provider, database sessions) ---

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]
  qrCodes  QrCode[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- App models ---

enum QrType {
  URL
  VCARD
  WIFI
  TEXT
  EMAIL
  PHONE
}

enum QrStatus {
  ACTIVE
  ARCHIVED
}

model BrandTemplate {
  id          String  @id @default(cuid())
  name        String
  foreground  String
  background  String
  dotStyle    String?
  cornerStyle String?
  logoUrl     String?
  isDefault   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qrCodes QrCode[]
}

model QrCode {
  id              String   @id @default(cuid())
  slug            String   @unique
  shortcode       String   @unique
  label           String
  type            QrType
  contentConfig   Json
  destinationUrl  String
  styleConfig     Json
  tags            String[] @default([])
  status          QrStatus @default(ACTIVE)

  brandTemplateId String?
  brandTemplate   BrandTemplate? @relation(fields: [brandTemplateId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scans Scan[]

  @@index([status])
  @@index([type, status, createdAt])
  @@index([createdAt])
  @@index([tags], type: Gin)
}

model Scan {
  id         String   @id @default(cuid())
  qrCodeId   String
  qrCode     QrCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  scannedAt  DateTime @default(now())
  userAgent  String?
  deviceType String?
  referrer   String?
  ipCountry  String?
  ipCity     String?

  @@index([qrCodeId, scannedAt])
  @@index([scannedAt])
}
